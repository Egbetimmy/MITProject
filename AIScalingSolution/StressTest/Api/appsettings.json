{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "PredictiveMiddleware": {
    "NonCriticalRoutePrefixes": [
      "/api/v1/promotions",
      "/api/promotions"
    ]
  },
  "PredictiveMiddleware:Redis": {
    "ConnectionString": "localhost:6379",
    "KeyPrefix": "api:telemetry:v1",
    "SlidingWindowDuration": "00:05:00"
  },
  "PredictiveMiddleware:Ingestion": {
    "QueueCapacity": 65536,
    "ConsumerCount": 4
  },
  "PredictiveMiddleware:Engine": {
    "EvaluationIntervalMilliseconds": 1000,
    "AggregateSeriesKey": "global",
    "WindowSizeSeconds": 120,
    "BucketIntervalSeconds": 1,
    "WindowSize": 30,
    "SeriesLength": 120,
    "TrainSize": 120,
    "Horizon": 60,
    "RefitEveryNCycles": 30,
    "BaselineRequestsPerBucket": 80,
    "AlertPeakMultiplier": 1.5,
    "CriticalPeakMultiplier": 2.0,
    "AccelerationThreshold": 40
  },
  "PredictiveMiddleware:Mitigation": {
    "NominalAuthenticatedRequestsPerMinute": 1000,
    "NominalUnauthenticatedRequestsPerMinute": 1000,
    "AlertAuthenticatedRequestsPerMinute": 400,
    "AlertUnauthenticatedRequestsPerMinute": 400,
    "CriticalAuthenticatedRequestsPerMinute": 200,
    "CriticalUnauthenticatedRequestsPerMinute": 20,
    "WarmupCacheKeys": [
      "catalog:featured",
      "catalog:bestsellers",
      "promotions:homepage"
    ]
  },
  "PredictiveMiddleware:Diagnostics": {
    "IntervalSeconds": 2
  }
}
