{
  "ReverseProxy": {
    "Routes": {
      "users-route": {
        "ClusterId": "users-cluster",
        "Match": { "Path": "/users/{**catch-all}" },
        "Transforms": [
          { "PathPattern": "/api/users/{**catch-all}" }
        ]
      },
      "users-root": {
        "ClusterId": "users-cluster",
        "Match": { "Path": "/users" },
        "Transforms": [
          { "PathPattern": "/api/users" }
        ]
      },
      "products-route": {
        "ClusterId": "products-cluster",
        "Match": { "Path": "/products/{**catch-all}" },
        "Transforms": [
          { "PathPattern": "/api/products/{**catch-all}" }
        ]
      },
      "products-root": {
        "ClusterId": "products-cluster",
        "Match": { "Path": "/products" },
        "Transforms": [
          { "PathPattern": "/api/products" }
        ]
      },
      "orders-route": {
        "ClusterId": "orders-cluster",
        "Match": { "Path": "/orders/{**catch-all}" },
        "Transforms": [
          { "PathPattern": "/api/orders/{**catch-all}" }
        ]
      },
      "orders-root": {
        "ClusterId": "orders-cluster",
        "Match": { "Path": "/orders" },
        "Transforms": [
          { "PathPattern": "/api/orders" }
        ]
      },
      "monitoring-route": {
        "ClusterId": "monitoring-cluster",
        "Match": { "Path": "/monitoring/{**catch-all}" },
        "Transforms": [
          { "PathPattern": "/api/{**catch-all}" }
        ]
      },
      "prediction-route": {
        "ClusterId": "prediction-cluster",
        "Match": { "Path": "/prediction/{**catch-all}" },
        "Transforms": [
          { "PathPattern": "/api/{**catch-all}" }
        ]
      }
    },
    "Clusters": {
      "users-cluster": {
        "Destinations": {
          "destination1": { "Address": "http://userservice:8080" }
        }
      },
      "products-cluster": {
        "Destinations": {
          "destination1": { "Address": "http://productservice:8080" }
        }
      },
      "orders-cluster": {
        "Destinations": {
          "destination1": { "Address": "http://orderservice:8080" }
        }
      },
      "monitoring-cluster": {
        "Destinations": {
          "destination1": { "Address": "http://monitoringservice:8080" }
        }
      },
      "prediction-cluster": {
        "Destinations": {
          "destination1": { "Address": "http://predictionservice:8080" }
        }
      }
    }
  },
  "PredictiveMiddleware": {
    "NonCriticalRoutePrefixes": [
      "/products"
    ],
    "AlertStatusHeaderName": "X-System-Status",
    "AlertStatusHeaderValue": "Alert-Mode"
  },
  "PredictiveMiddleware:Redis": {
    "ConnectionString": "redis:6379",
    "KeyPrefix": "gateway:telemetry:v1",
    "SlidingWindowDuration": "00:05:00"
  },
  "PredictiveMiddleware:Ingestion": {
    "QueueCapacity": 65536,
    "ConsumerCount": 4
  },
  "PredictiveMiddleware:Engine": {
    "EvaluationIntervalMilliseconds": 1000,
    "AggregateSeriesKey": "global",
    "WindowSizeSeconds": 120,
    "BucketIntervalSeconds": 1,
    "WindowSize": 30,
    "SeriesLength": 120,
    "TrainSize": 120,
    "Horizon": 60,
    "RefitEveryNCycles": 30,
    "BaselineRequestsPerBucket": 80,
    "AlertPeakMultiplier": 1.5,
    "CriticalPeakMultiplier": 2.0,
    "AccelerationThreshold": 40
  },
  "PredictiveMiddleware:Mitigation": {
    "NominalAuthenticatedRequestsPerMinute": 1000,
    "NominalUnauthenticatedRequestsPerMinute": 1000,
    "AlertAuthenticatedRequestsPerMinute": 400,
    "AlertUnauthenticatedRequestsPerMinute": 400,
    "CriticalAuthenticatedRequestsPerMinute": 200,
    "CriticalUnauthenticatedRequestsPerMinute": 20,
    "WarmupCacheKeys": [
      "catalog:featured",
      "catalog:bestsellers",
      "products:homepage"
    ]
  },
  "PredictiveMiddleware:Diagnostics": {
    "IntervalSeconds": 2
  },
  "GatewayIntelligence": {
    "Enabled": true,
    "MonitoringBaseUrl": "http://monitoringservice:8080",
    "PredictionBaseUrl": "http://predictionservice:8080",
    "SamplingRate": 0.1,
    "RequestTimeoutSeconds": 2,
    "ModelReadinessCacheSeconds": 30,
    "RetryCount": 2,
    "ScaleDecisionHeaderName": "X-Scale-Decision",
    "PredictedLoadHeaderName": "X-Predicted-Load"
  },
  "OpenTelemetry": { "OtlpEndpoint": "" },
  "AllowedHosts": "*"
}
